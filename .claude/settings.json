{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/aaron/.claude/hooks/delimit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit && (path_matches('**/openapi*') || path_matches('**/swagger*') || path_matches('**/*.yaml') || path_matches('**/*.yml'))",
        "hooks": [
          {
            "type": "command",
            "command": "delimit-cli hook pre-tool $TOOL_NAME"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash && (input_contains('git commit') || input_contains('git push'))",
        "hooks": [
          {
            "type": "command",
            "command": "delimit-cli hook pre-commit"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "command matches 'git commit'",
        "hooks": [
          {
            "type": "command",
            "command": "delimit-cli doctor",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "command matches 'npm publish' or command matches 'npx deploy' or command matches 'deploy' or command matches 'release' or command matches 'docker compose up' or command matches 'docker-compose up' or command matches 'docker build'",
        "hooks": [
          {
            "type": "command",
            "command": "delimit-cli hook deploy-gate",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "path_matches('**/openapi*.yaml') || path_matches('**/openapi*.yml') || path_matches('**/openapi*.json') || path_matches('**/swagger*.yaml') || path_matches('**/swagger*.yml') || path_matches('**/swagger*.json')",
        "hooks": [
          {
            "type": "command",
            "command": "delimit-cli lint \"$DELIMIT_FILE_PATH\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/aaron/.claude/hooks/delimit-stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}