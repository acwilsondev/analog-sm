# Copy this file to .env and fill in ALL values before running.
# Never commit real secrets. Generate secrets with: openssl rand -hex 32

# Database — used by both the app and the postgres container
POSTGRES_USER=analoguser
POSTGRES_PASSWORD=                        # REQUIRED: set a strong password
POSTGRES_DB=analogdb
DATABASE_URL="postgresql://analoguser:CHANGE_ME@postgres:5432/analogdb"

# NextAuth — REQUIRED: generate with: openssl rand -hex 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=                          # REQUIRED: never leave empty or use a placeholder

# S3 / MinIO Storage — REQUIRED: change from defaults before deploying
S3_ENDPOINT="http://minio:9000"
S3_PUBLIC_URL="http://localhost:9000"
S3_ACCESS_KEY=                            # REQUIRED: change from minioadmin default
S3_SECRET_KEY=                            # REQUIRED: change from minioadmin default
S3_BUCKET="analog-sm"

# Node Environment
NODE_ENV="development"
