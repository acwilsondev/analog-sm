generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("member")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  entries       Entry[]
  collections   Collection[]
  likes         Like[]
  comments      Comment[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // e.g., "LIKE", "COMMENT", "MENTION"
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Entry {
  id          String   @id @default(cuid())
  authorId    String
  tombstonedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  revisions   Revision[]
  collections CollectionEntry[]
  likes       Like[]
  comments    Comment[]
  tags        TagsOnEntries[]

  @@index([authorId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  entries   TagsOnEntries[]
}

model TagsOnEntries {
  entryId String
  tagId   String
  entry   Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
}

model Revision {
  id        String   @id @default(cuid())
  entryId   String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  media     Media[]

  @@index([entryId])
}

model Media {
  id         String      @id @default(cuid())
  revisionId String?     // Optional during upload init
  fileName   String
  fileSize   Int
  mimeType   String
  s3Key      String
  sha256     String?
  blurHash   String?
  status     MediaStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  revision   Revision?   @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([revisionId])
}

model Collection {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  createdAt   DateTime @default(now())

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  entries     CollectionEntry[]

  @@index([ownerId])
}

model CollectionEntry {
  entryId      String
  collectionId String
  createdAt    DateTime @default(now())

  entry      Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([entryId, collectionId])
}

model Like {
  userId    String
  entryId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([userId, entryId])
}

model Comment {
  id        String   @id @default(cuid())
  authorId  String
  entryId   String
  parentId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("Thread", fields: [parentId], references: [id])
  replies   Comment[] @relation("Thread")

  @@index([authorId])
  @@index([entryId])
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  email     String?
  role      String   @default("member")
  usedAt    DateTime?
  expiresAt DateTime?
  maxUses   Int      @default(1)
  useCount  Int      @default(0)
  createdBy String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum MediaStatus {
  PENDING
  READY
  FAILED
}

model BootstrapState {
  id              Int      @id @default(1)
  bootstrapUsedAt DateTime?
}
