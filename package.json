{
  "name": "analog-sm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/app/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts src/app/**/*.test.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migrate": "bash scripts/exec-in-app.sh prisma migrate deploy",
    "db:migrate:dev": "bash scripts/exec-in-app.sh prisma migrate dev",
    "create-admin": "bash scripts/exec-in-app.sh node dist/scripts/create-admin.js",
    "create-invite": "bash scripts/exec-in-app.sh node dist/scripts/create-invite.js",
    "deactivate-user": "bash scripts/exec-in-app.sh node dist/scripts/deactivate-user.js",
    "archive:verify": "bash scripts/exec-in-app.sh node dist/scripts/archive-verify.js",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "backup:validate": "bash scripts/backup-restore-validate.sh"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@auth/express": "^0.12.1",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.1021.0",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prisma/client": "^6.0.1",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.6",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0"
  }
}
